# 复制为 .env.local 后填入实际值

# ─── AI 推理：智谱 BigModel（OpenAI 兼容协议）───
AI_PROVIDER=zhipu
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.6v

# ─── 备用：DeepSeek 等其他 OpenAI 兼容模型 ───
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ─── 或用其他 OpenAI 兼容模型 ───
# AI_PROVIDER=mimo
# MIMO_API_KEY=your-api-key
# MIMO_BASE_URL=https://your-provider/v1
# MIMO_MODEL=model-name

# ─── 站点 ───
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# 后台统计访问口令：设置后访问 /admin?token=your-admin-token
ADMIN_ACCESS_TOKEN=your-admin-token

# 匿名访客哈希盐，生产环境建议改成随机长字符串
VISITOR_HASH_SECRET=your-random-secret

# 可选：生产环境建议配置 Redis，避免 Serverless 文件系统不持久导致统计丢失
# REDIS_URL=redis://default:password@host:6379
